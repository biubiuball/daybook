{
  "name": "daybook",
  "private": true,
  "type": "module",
  "scripts": {
    "build:vendor-fonts": "node scripts/build-vendor-fonts.mjs",
    "fetch:font-sources": "bash tools/font-subsets/fetch-font-sources.sh",
    "build:decorative-fonts": "bash tools/font-subsets/build.sh",
    "build:all-fonts": "npm run build:vendor-fonts && npm run build:decorative-fonts",
    "render:katex": "node scripts/render-katex.mjs",
    "typecheck": "tsc --noEmit",
    "build:js": "node scripts/build-js.mjs",
    "watch:js": "node scripts/build-js.mjs --watch",
    "build": "./scripts/build.sh",
    "serve": "./scripts/serve.sh"
  },
  "dependencies": {
    "jsdom": "^29.1.1",
    "katex": "^0.16.10",
    "puppeteer": "^25.1.0"
  },
  "version": "1.0.0",
  "description": "A minimalist static blog generator for Go and HTML beginners.",
  "main": "patch.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StatIndet/daybook.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/StatIndet/daybook/issues"
  },
  "homepage": "https://github.com/StatIndet/daybook#readme",
  "devDependencies": {
    "@chinese-fonts/maple-mono-cn": "^2.0.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "lxgw-wenkai-screen-web": "^1.522.0",
    "material-symbols": "^0.45.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
